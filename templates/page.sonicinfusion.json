 video = document.getElementById(\"video\");\n    const audioControl = document.getElementById(\"audioControl\");\n\n    \/\/ Toggle mute\/unmute and play audio on click\n    const toggleAudio = () => {\n      if (video.muted) {\n        video.muted = false; \/\/ Unmute the video\n        video.play(); \/\/ Ensure video starts playing\n        audioControl.textContent = \"🔊\"; \/\/ Update icon to unmuted\n      } else {\n        video.muted = true; \/\/ Mute the video\n        audioControl.textContent = \"🔇\"; \/\/ Update icon to muted\n      }\n    };\n\n    \/\/ Add event listeners to video and control icon\n    video.addEventListener(\"click\", toggleAudio);\n    audioControl.addEventListener(\"click\", toggleAudio);\n\n    \/\/ Initialize icon state\n    audioControl.textContent = \"🔇\";\n  });\n<\/script>"}}},"order":["main","video_video_NWQf94","text_rich_text_xNznXq","text_rich_text_8NpUCr","video_video_hero_WEj46k","image_image_with_text_TFkrep","image_image_with_text_thYHVY","image_slideshow_YD4fi6","image_gallery_piyMcy","image_slideshow_YYaer6","section_contact_form_3mBCAw","text_rich_text_QiyKcW","collage_builder_Ukx7CT","advanced_layout_custom_liquid_eDpJzt"]}