{"sections":{"video_video_P966wD":{"type":"video--video","custom_css":["@media only screen and (max-width: 768px) {\/* if your video tag has class \"hero-video-mp4\": *\/ .hero-video-mp4 {width: 100% !important; height: 40vh !important; \/* 60% of viewport height *\/ object-fit: cover !important; \/* fill the container *\/ } \/* ensure its wrapper doesn’t collapse: *\/ .native-video-wrapper, .video--video_mp4 {height: 40vh !important; }}"],"name":"t:all.Video","settings":{"colors":"accent","title":"","richtext":"","width_classes":75,"video":"shopify:\/\/files\/videos\/About American Metal Whiskey Story - General Public Version Final.mp4","url":"","autoplay":false,"loop":true,"mute":false,"image":"shopify:\/\/shop_images\/About_American_Metal_Whiskey.jpg","video_overlay_opacity":0}},"advanced_layout_custom_liquid_Yd4cbE":{"type":"advanced-layout--custom-liquid","custom_css":["{background-color: #171616; margin-bottom: 0px;}"],"settings":{"custom_liquid":"<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<link rel=\"stylesheet\" href=\"your-stylesheet.css\"> <!-- Replace with the actual path to your stylesheet -->\n<title>American Metal Whiskey<\/title>\n<style>\n  .content-container {\n    display: flex;\n    align-items: center;\n    gap: 100px;\n    padding: 100px 200px;\n  }\n  .content-image {\n    flex: 0 0 30%;\n  }\n  .content-image img {\n    max-width: 100%;\n    height: auto;\n  }\n  .content-text {\n    flex: 0 0 70%;\n    text-align: left;\n  }\n\n  @media (max-width: 768px) {\n    .content-container {\n      flex-direction: column;\n      gap: 20px;\n      padding: 0px 20px;\n    }\n    .content-image, .content-text {\n      flex: 1 0 100%;\n      text-align: center;\n    }\n    .content-image img {\n      width: 80%;\n      height: auto;\n    }\n  }\n<\/style>\n\n<div class=\"content-container\">\n  <div class=\"content-image\">\n    <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0871\/8879\/9797\/files\/am_cm_logo_large_10c43bcf-ee5a-4651-ad6a-5921f222961a.png?v=1725562984\" alt=\"American Metal Whiskey Logo\">\n  <\/div>\n  <div class=\"content-text\">\n    <p>\n      Welcome to American Metal Whiskey, where we blend the passion of craftsmanship with the spirit of custom car and motorcycle culture. Our authenticity comes from our award-winning custom shop led by Josh Allison, known for crafting custom cars and motorcycles that embody the vintage design and raw elegance of hand-made American craftsmanship. In 2021, we took that same attention to detail and world-class craftsmanship and created an award-winning whiskey brand that reflects the artistry, innovation, and spirit of our custom legacy. Learn more at <a href=\"https:\/\/www.americanmetalcustom.com\/\" target=\"_blank\">American Metal Customs<\/a>.\n    <\/p>\n  <\/div>\n<\/div>"}},"image_image_with_text_TAk8xF":{"type":"image--image-with-text","custom_css":["@media only screen and (min-width: 768px) {p {font-size: 18px; padding-right: 100px !important; padding-left: 100px !important; } .grid--full {max-height: 700px !important; } img {object-fit: cover; min-height: 500px; }}","@media only screen and (max-width: 769px) {p {text-align: left !important; font-size: 16.5px; margin-bottom: -30px !important; }}"],"settings":{"image":"shopify:\/\/shop_images\/Selects.04_23_52_21.Still030.webp","text_overlapping_image":false,"section-width":"full","layout":"left","text_alignment":"left","title":"","text":"<p>Our whiskey is crafted with the finest ingredients and traditional methods, honoring the rich heritage of American whiskey-making while pushing the boundaries of innovation. Each batch is carefully produced to deliver an exceptional drinking experience that mirrors the attention to detail found in every custom car and bike we build. With iconic packaging inspired by the custom car and motorcycle culture, our whiskey is as bold and distinct as the machines that inspire it.<\/p>","button_label":"","button_li