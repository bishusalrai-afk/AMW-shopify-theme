{"sections":{"video_video_hero_z6WVpi":{"type":"video--video-hero","custom_css":[".hero-video-mp4 {width: 100%; height: 100%;}","@media only screen and (max-width: 768px) {.desktop-height-fullscreen {margin-top: 40px; }}"],"settings":{"video":"shopify:\/\/files\/videos\/AMW - Whiskey Commercial Update 30sec.mp4","url":"","desktopHeight":"fullscreen","mobileHeight":"450","title":"","subheading":"","textAlignment":"center","textShadow":false,"heading--text-size":16,"subheading--text-size":12,"link":"","button_label":"","textColor":"#000000","button-text":"#ffffff","button-background":"rgba(0,0,0,0)"}},"advanced_layout_custom_liquid_ABf4RF":{"type":"advanced-layout--custom-liquid","disabled":true,"name":"t:all.Custom_Liquid","settings":{"custom_liquid":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" \/>\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"\/>\n  <title>Scroll Scrub Video<\/title>\n  <style>\n    body {\n      margin: 0;\n      padding: 0;\n      font-family: sans-serif;\n      background: #000;\n    }\n\n    .spacer {\n      height: 100vh;\n    }\n\n    .video-container {\n      height: 100vh;\n      position: relative;\n      overflow: hidden;\n    }\n\n    video {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      pointer-events: none;\n    }\n  <\/style>\n<\/head>\n<body>\n\n  <div class=\"spacer\"><\/div>\n\n  <div class=\"video-container\">\n    <video id=\"scrollVideo\" muted playsinline preload=\"auto\">\n      <source src=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/ee97c9c09f064f5fba8f9cfb33155ba0.mp4\" type=\"video\/mp4\">\n    <\/video>\n  <\/div>\n\n  <div class=\"spacer\"><\/div>\n\n  <script src=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/gsap\/3.12.2\/gsap.min.js\"><\/script>\n  <script src=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/gsap\/3.12.2\/ScrollTrigger.min.js\"><\/script>\n\n  <script>\n    const video = document.getElementById('scrollVideo');\n\n    video.addEventListener('loadedmetadata', () => {\n      gsap.registerPlugin(ScrollTrigger);\n\n      \/\/ total scrub time based on scroll\n      gsap.to(video, {\n        currentTime: video.duration,\n        ease: \"none\",\n        scrollTrigger: {\n          trigger: \".video-container\",\n          start: \"top top\",\n          end: \"bottom top\",\n          scrub: true,\n          pin: true,\n        }\n      });\n    });\n  <\/script>\n<\/body>\n<\/html>"}},"text_rich_text_TC6qWb":{"type":"text--rich-text","blocks":{"heading_XGNhae":{"type":"heading","settings":{"heading":"AMERICAN METAL WHISKEY"}},"richtext_Nbh3rY":{"type":"richtext","settings":{"text":"<p>American Metal Whiskey is an award-winning whiskey that embodies the same values of craftsmanship, creativity, and attention to detail that go into every hot rod and bike built by the American Metal Custom Shop. Craftsmanship Matters, whether in the Garage or the Distillery. No shortcuts, no compromises – that's how we build custom cars and bikes, and that's how we craft American Metal Whiskey.<\/p>","text_size":12}},"button_NX8KNc":{"type":"button","settings":{"button_link":"shopify:\/\/pages\/about","button_text":"Learn More"}}},"block_order":["heading_XGNhae","richtext_Nbh3rY","button_NX8KNc"],"custom_css":["h2 {padding-top: 30px; padding-bottom: 20px;}",".btn {margin-bottom: 30px;}"],"settings":{"section_width":"narrow","text_alignment_desktop":"center","text_alignment_mobile":"center","colors":"accent"}},"text_rich_text_z3VpAB":{"type":"text--rich-text","blocks":{"heading_Rn68gQ":{"type":"heading","settings":{"heading":"FOR RETAILERS, BARS & RESTAURANTS"}},"richtext_CHKFGp":{"type":"richtext","settings":{"text":"<p>HAVE AMERICAN METAL WHISkeY DELIVERED DIRECTLY TO YOU!<\/p><p>PLEASE EMAIL US AT <a href=\"mailto:info@americanmetalwhiskey.com\">info@americanmetalwhiskey.com<\/a> AND OUR TEAM WILL GET YOU SET UP AS AN ACCOUNT.<\/p>","text_size":18}},"heading_Va7aAb":{"type":"heading","settings":{"heading":