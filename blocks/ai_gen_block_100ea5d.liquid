{% doc %}
  @prompt
    separater
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-separator-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: {{ block.settings.spacing_top }}px auto {{ block.settings.spacing_bottom }}px;
  }

  .ai-separator-line-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.line_thickness }}px;
    background-color: {{ block.settings.line_color }};
    border: none;
    margin: 0;
    {% if block.settings.line_style == 'dashed' %}
      background: repeating-linear-gradient(
        to right,
        {{ block.settings.line_color }} 0px,
        {{ block.settings.line_color }} {{ block.settings.dash_length }}px,
        transparent {{ block.settings.dash_length }}px,
        transparent {{ block.settings.dash_length | plus: block.settings.dash_gap }}px
      );
    {% elsif block.settings.line_style == 'dotted' %}
      background: repeating-linear-gradient(
        to right,
        {{ block.settings.line_color }} 0px,
        {{ block.settings.line_color }} {{ block.settings.line_thickness }}px,
        transparent {{ block.settings.line_thickness }}px,
        transparent {{ block.settings.line_thickness | plus: block.settings.dot_gap }}px
      );
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-separator-{{ ai_gen_id }} {
      margin: {{ block.settings.spacing_top_mobile }}px auto {{ block.settings.spacing_bottom_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-separator-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <hr class="ai-separator-line-{{ ai_gen_id }}">
</div>

{% schema %}
{
  "name": "Separator",
  "settings": [
    {
      "type": "header",
      "content": "Line style"
    },
    {
      "type": "select",
      "id": "line_style",
      "label": "Style",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "dashed",
          "label": "Dashed"
        },
        {
          "value": "dotted",
          "label": "Dotted"
        }
      ],
      "default": "solid"
    },
    {
      "type": "range",
      "id": "line_thickness",
      "label": "Thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "dash_length",
      "label": "Dash length",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "dash_gap",
      "label": "Dash gap",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "dot_gap",
      "label": "Dot gap",
      "min": 2,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Color",
      "default": "#322d2d"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Top spacing (desktop)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Bottom spacing (desktop)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "spacing_top_mobile",
      "label": "Top spacing (mobile)",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_bottom_mobile",
      "label": "Bottom spacing (mobile)",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Separator"
    }
  ]
}
{% endschema %}
